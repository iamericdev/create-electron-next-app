{
  "appId": "com.example.app",
  "productName": "Electron Next App",
  "files": [
    "dist-electron",
    "!node_modules/**/*",
    "!.next/**/*",
    "!src/**/*",
    "!electron/**/*",
    "!public/**/*"
  ],
  "extraResources": [
    "dist-electron/preload.js",
    {
      "from": ".next/standalone",
      "to": "next-standalone",
      "filter": [
        "**/*",
        "!node_modules/canvas/**",
        "!**/.next/node_modules/canvas/**"
      ]
    },
    {
      "from": ".next/standalone/node_modules",
      "to": "next-standalone/node_modules"
    }
  ],
  "icon": "./desktopIcon.png",
  "npmRebuild": false,
  "asarUnpack": ["resources/next-standalone/**/*"],
  "publish": [
    {
      "provider": "github",
      "owner": "github username",
      "repo": "case-repository-app"
    }
  ],
  "mac": {
    "target": "dmg"
  },
  "linux": {
    "target": "AppImage",
    "category": "Utility"
  },
  "win": {
    "target": ["nsis"]
  }
}
